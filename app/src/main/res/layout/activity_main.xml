<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    tools:context=".MainActivity">

    <!-- 1. 网络配置卡片 -->
    <LinearLayout
        android:id="@+id/layout_config"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E8EAF6"
        android:padding="12dp"
        android:layout_alignParentTop="true"
        android:elevation="4dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_local_ip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="本地IP: 检测中..."
            android:textColor="#1A237E"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <TextView
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:text="本地端口:"/>
            <EditText
                android:id="@+id/et_local_port"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="number"
                android:text="12345"
                android:textSize="14sp"/>
            <Button
                android:id="@+id/btn_apply_config"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="启动"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#C5CAE9"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:text="目标IP:"/>
            <EditText
                android:id="@+id/et_remote_ip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="222.198.39.29"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:text="目标端口:"/>
            <EditText
                android:id="@+id/et_remote_port"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="12346"
                android:textSize="14sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 2. 数据解析展示卡片 -->
    <LinearLayout
        android:id="@+id/layout_sensors"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layout_config"
        android:background="#F1F8E9"
        android:orientation="vertical"
        android:padding="12dp"
        android:elevation="4dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="实时数据解析"
            android:textColor="#33691E"
            android:textStyle="bold"
            android:textSize="14sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:columnCount="2"
            android:rowCount="2">

            <TextView
                android:id="@+id/tv_sensor_temp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="温度: -- ℃"
                android:textSize="16sp"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tv_sensor_humi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="湿度: -- %"
                android:textSize="16sp"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tv_sensor_person"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginTop="8dp"
                android:text="人员检查: --"
                android:textSize="16sp"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tv_sensor_co2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginTop="8dp"
                android:text="CO2: -- ppm"
                android:textSize="16sp"
                android:textColor="#212121" />
        </GridLayout>
    </LinearLayout>

    <!-- 3. 发送控制区域 -->
    <Button
        android:id="@+id/button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:backgroundTint="#3F51B5"
        android:textColor="#FFFFFF"
        android:text="发送数据" />

    <RelativeLayout
        android:id="@+id/relativeout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/button"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/textview_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="内容:"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edittext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/textview_label"
            android:hint="输入消息..."/>

    </RelativeLayout>

    <!-- 4. 历史记录展示 -->
    <ListView
        android:id="@+id/listview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/relativeout"
        android:layout_below="@id/layout_sensors"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:background="#FAFAFA"
        android:divider="#EEEEEE"
        android:dividerHeight="1dp" />

</RelativeLayout>